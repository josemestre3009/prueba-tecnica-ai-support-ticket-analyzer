# ── IA ──────────────────────────────────────────────────────────────────────
# Modo de operación: "mock" no requiere API key (ideal para demo)
AI_MODE=mock
AI_MODEL=mock

# Descomenta el proveedor que quieras usar y añade tu API key:

# Anthropic
# AI_MODE=real
# AI_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (tier gratuito generoso, muy rápido)
# AI_MODE=real
# AI_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# Google Gemini
# AI_MODE=real
# AI_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=...

# OpenAI
# AI_MODE=real
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/tickets.db
DATASET_PATH=./dataset/tickets.csv
AUTO_INGEST_ON_START=true
